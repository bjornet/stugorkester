# Database (Drizzle / better-sqlite3)
DATABASE_URL=local.db

# Worker: how often to poll active channel feeds, in minutes (default 15).
SYNC_INTERVAL_MINUTES=15

# Notifications (optional). Without SMTP_URL the worker logs alerts instead of
# sending them; without ALERT_EMAIL_TO it skips them entirely.
# SMTP_URL=smtps://user:password@smtp.example.com
# ALERT_EMAIL_FROM=stugorkester@example.com
# ALERT_EMAIL_TO=owner@example.com
